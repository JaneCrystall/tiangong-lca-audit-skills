# Tiangong platform integration. Never commit a real access token.
TIANGONG_SUPABASE_URL=
TIANGONG_SUPABASE_ANON_KEY=

# Admin account: reads admin queue and saves rejection/return drafts after confirmation.
TIANGONG_ADMIN_ACCESS_TOKEN=
TIANGONG_ADMIN_EMAIL=
TIANGONG_ADMIN_PASSWORD=

# Member/reviewer account: reads member queue and saves pass drafts after confirmation.
TIANGONG_MEMBER_ACCESS_TOKEN=
TIANGONG_MEMBER_EMAIL=
TIANGONG_MEMBER_PASSWORD=

TIANGONG_API_ALLOW_WRITES=false

# document-granular-decompose Skill: image-aware source parsing via /mineru_with_images.
# Required when parsing PDF/Office/image sources with that Skill.
UNSTRUCTURED_API_BASE_URL=https://your-unstructured-host:7770
# Full endpoint is also accepted:
# UNSTRUCTURED_API_BASE_URL=https://your-unstructured-host:7770/mineru_with_images
UNSTRUCTURED_AUTH_TOKEN=
# Optional routing overrides; leave commented to use service defaults.
# UNSTRUCTURED_PROVIDER=vllm
# UNSTRUCTURED_MODEL=Qwen/Qwen3.5-122B-A10B-FP8
